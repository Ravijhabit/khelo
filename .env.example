# Ghost Coach — Environment Variables
# Copy this file to .env and fill in your values

# Gemini Vision API key (free via Google AI Studio: aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret (any long random string, min 32 characters)
JWT_SECRET=replace-this-with-a-long-random-secret-key-32chars
